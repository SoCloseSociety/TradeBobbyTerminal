# TradeBobby dashboard -- optional API keys.
# Copy to `.env` (gitignored). manage.sh auto-loads `.env` before starting daemons,
# so every daemon inherits these via process.env. NEVER commit `.env`.

# ── AI narration (claude-narrator.js) ── the real "intelligence" data completion.
# ANTHROPIC_API_KEY is reusable from the TradingForge server .env (same var name).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Alerts (setup-alerter.js) ── all optional; alerts simply stay silent if unset.
# TELEGRAM_BOT_TOKEN is reusable from the server. TELEGRAM_CHAT_ID is the destination
# chat (your own Telegram user id works for DMs -- the server stores it as
# TELEGRAM_AUTHORIZED_USER_IDS). DISCORD_WEBHOOK_URL is not on the server; set it yourself.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
