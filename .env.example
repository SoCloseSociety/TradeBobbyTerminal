# TradeBobby -- environment template. Copy to .env (gitignored) and fill in what you use.
# Most scanners run with NO env vars; everything below is optional unless noted.
# No em dashes in this repo by convention. Use "--".

# Path to the TradingView MCP engine (the `tv` CLI lives here). Used by scan.js / auto-scan.js / start-agent.sh.
TV_MCP_DIR=/Users/neo/tradingview-mcp-jackson

# Dashboard HTTP port (server binds 127.0.0.1 only -- localhost dashboard, no auth).
PORT=3333

# AI narration (optional; only claude-narrator.js calls the API).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Notifications (optional; setup-alerter.js / trade-agent.js).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Broker / execution (optional; default is paper/none -- do NOT wire live without review).
BROKER_MODE=none
CTRADER_ACCOUNT_ID=
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
MT_ACCOUNT_ID=
MT_API_TOKEN=
MT_REGION=

# Paper / mock account.
MOCK_BALANCE=10000
MOCK_CURRENCY=USD
MOCK_LEVERAGE=30

# Node binary override (start-agent.sh), and runtime flags.
NODE_BIN=node
NODE_ENV=production
DEBUG=
